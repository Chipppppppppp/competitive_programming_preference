// 既定値を上書きするには、このファイル内にキー バインドを挿入します
[
    {
        "key": "alt+n",
        "command": "explorer.newFile"
    },
    {
        "key": "alt+shift+n",
        "command": "explorer.newFolder"
    },
    {
        "key": "alt+shift+enter",
        "command": "extension.multiCommand.execute",
        "args": {
            "sequence": [
                "workbench.action.files.saveAll",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": {
                        "text": "pypy3 ${file} < ~/competitive_programming/work/input.txt > ~/competitive_programming/work/output.txt 2> ~/competitive_programming/work/error.txt\n"
                    }
                }
            ]
        },
        "when": "workspaceFolder == ~/competitive_programming && resourceExtname == .py"
    },
    {
        "key": "alt+enter",
        "command": "extension.multiCommand.execute",
        "args": {
            "sequence": [
                "workbench.action.files.saveAll",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": {
                        "text": "oj-bundle -I/usr/include -I/root/competitive_programming/ac-library -I/root/competitive_programming/kyopro ${file} > ~/competitive_programming/work/bundled.cpp 2> ~/competitive_programming/work/bundle_error.txt & > ~/competitive_programming/work/error.txt && g++ -std=gnu++20 -O2 -Wall -Wextra -mtune=native -march=native -fconstexpr-depth=2147483647 -fconstexpr-loop-limit=2147483647 -fconstexpr-ops-limit=2147483647 -Igmpxx -Igmp -I/usr/include -I/root/competitive_programming/ac-library -I/root/competitive_programming/kyopro -o ~/competitive_programming/work/a.out ${file} 2> ~/competitive_programming/work/output.txt && time ~/competitive_programming/work/a.out < ~/competitive_programming/work/input.txt > ~/competitive_programming/work/output.txt 2> ~/competitive_programming/work/error.txt\n"
                    }
                }
            ]
        },
        "when": "workspaceFolder == ~/competitive_programming && resourceExtname == .cpp"
    },
    {
        "key": "alt+backspace",
        "command": "extension.multiCommand.execute",
        "args": {
            "sequence": [
                "workbench.action.files.saveAll",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": {
                        "text": "cp ~/competitive_programming/template/template${fileExtname} ${file}\n"
                    }
                }
            ]
        },
        "when": "workspaceFolder == ~/competitive_programming && (resourceExtname == .py || resourceExtname == .cpp)"
    }
]
