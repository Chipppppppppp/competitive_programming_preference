[
    {
        "key": "alt+n",
        "command": "explorer.newFile"
    },
    {
        "key": "alt+shift+n",
        "command": "explorer.newFolder"
    },
    {
        "key": "alt+enter",
        "command": "extension.multiCommand.execute",
        "args": {
            "sequence": [
                "workbench.action.files.saveAll",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": {
                        "text": "cd ${workspaceFolder} && pypy3 ${file} < work/input.txt > work/output.txt 2> work/error.txt\n"
                    }
                }
            ]
        },
        "when": "config.workspaceKeybindings.competitive_programming.enabled && resourceExtname == .py"
    },
    {
        "key": "alt+enter",
        "command": "extension.multiCommand.execute",
        "args": {
            "sequence": [
                "workbench.action.files.saveAll",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": {
                        "text": "cd ${workspaceFolder} && { oj-bundle -Iac-library -Ikyopro ${file} > work/bundled.cpp 2> work/bundle_error.txt & > work/error.txt && g++ -std=gnu++23 -O2 -Wall -Wextra -mtune=native -march=native -Iac-library -Ikyopro -o work/a.out ${file} 2> >(tee work/output.txt > work/compile_error.txt) && time work/a.out < work/input.txt > work/output.txt 2> work/error.txt & wait; }\n"
                    }
                }
            ]
        },
        "when": "config.workspaceKeybindings.competitive_programming.enabled && resourceExtname == .cpp"
    },
    {
        "key": "alt+backspace",
        "command": "extension.multiCommand.execute",
        "args": {
            "sequence": [
                "workbench.action.files.saveAll",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": {
                        "text": "cd ${workspaceFolder} && cp template/template${fileExtname} ${file}\n"
                    }
                }
            ]
        },
        "when": "config.workspaceKeybindings.competitive_programming.enabled && (resourceExtname == .py || resourceExtname == .cpp)"
    }
]
