{
	"dijkstra": {
		"prefix": "dijkstra",
		"body": [
			"Vl dist($1, inf);",
			"HQll2 hq;"
			"hq.emplace(dist[0] = 0, 0);",
			"while (!hq.empty()) {",
			"	auto [c, i] = hq.top();",
			"	hq.pop();",
			"	if (dist[i] < c) continue;",
			"	for (auto [ni, cost]: $2[i]) {",
			"		ll nc = c + cost;",
			"		if (chmin(dist[ni], nc)) hq.emplace(nc, ni);",
			"	}",
			"}",
			"println(dist.back());"
		]
	}
}
